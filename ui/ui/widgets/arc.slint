    //     stroke: stroke-color;
    //     stroke-width: stroke-width;
    //     // This is available in the next version, but we will need to update our Linecap definition
    //     // or just use Slint's.
    //     // stroke-line-cap: LineCap.butt;
    //     fill: transparent;
    //
    //     MoveTo {
    //         x: r + r * cos(0deg);
    //         y: r + r * sin(0deg);
    //     }
    //
