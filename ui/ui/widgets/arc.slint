    //     // This is available in the next version, but we will need to update our Linecap definition
    //     // or just use Slint's.
    //     // stroke-line-cap: LineCap.butt;
    //     fill: transparent;
    //
    //     MoveTo {
    //         x: r + r * cos(start-angle * 1deg - 90deg);
    //         y: r + r * sin(start-angle * 1deg - 90deg);
    //     }
    //
    //     ArcTo {
    //         x: r + r * cos(end-angle * 1deg - 90deg);
    //         y: r + r * sin(end-angle * 1deg - 90deg);
    //         radius-x: r;
    //         radius-y: r;
    //         large-arc: end-angle - start-angle > 180;
    //         sweep: true;
    //     }
    // }
    //
    // if full-circle: Path {
    //     width: size;
