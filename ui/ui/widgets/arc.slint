import {UISize, Palette, Size, Linecap, Utils} from "@ui/theme.slint";

export component Arc {
    // Public properties
    in property <string> id;
    in property <length> size: Size.sz10;
    in property <float> start-angle: 0.0;
    in property <float> end-angle: 270.0;
    in property <color> stroke-color: Palette.content-brand;
    in property <length> stroke-width: Size.sz4;
    in property <Linecap> stroke-linecap: Linecap.round;

    // Private properties
    private property <float> r: size / 1px / 2;

    // #IF PREVIEW
    // private property <bool> full-circle: start-angle + end-angle == 360.0;
