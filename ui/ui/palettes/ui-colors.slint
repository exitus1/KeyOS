export global UIGradients {
    out property <brush> switch-indeterminate: @linear-gradient(90deg, UIColors.teal-400 0%, UIColors.blue-500 100%);
    out property <brush> copper: @linear-gradient(90deg, UIColors.dark-copper-500 0%, UIColors.dark-copper-400 100%);
    // TBD: Add more gradients
}
