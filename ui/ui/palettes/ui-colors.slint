// Global colors used in all palettes

export global UIColors {
    // Primary
    out property <brush> primary-white: #ffffff;
    out property <brush> primary-black: #000000;
    out property <brush> transparent: #ffffff00;

    // Neutral
    out property <brush> neutral-950: #231f20;
    out property <brush> neutral-900: #454444;
    out property <brush> neutral-800: #5a595a;
    out property <brush> neutral-700: #747374;
