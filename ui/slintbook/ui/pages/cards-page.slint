import {Page} from "./page.slint";
import {AccountCard, Button, SlideToButton, HeadingMd, TextMd, LineCard, CardCircle, CardPill, HeadingSm, Icon} from "@ui/widgets.slint";
import {Size, CardColor} from "@ui/theme.slint";
import {UIColors} from "@ui/palettes/ui-colors.slint";

export component CardsPage inherits Page {
    private property <string> output;
    clip: false;

    VerticalLayout {
        spacing: Size.sz6;

        HeadingSm {
            text: "Cards";
        }

        HorizontalLayout {
            spacing: Size.sz6;
            LineCard {
                card-color: CardColor.blue;
                width: 416px;
                height: 144px;

                HorizontalLayout {
                    padding: Size.sz4;
                    alignment: end;
                    VerticalLayout {
                        alignment: center;
                        CardCircle {
                            line-color: CardColor.blue;
                            Icon {
                                name: "bitcoin";
                                size: 60px;
                                color: UIColors.primary-white;
                            }
                        }
                    }
                }
            }

            LineCard {
                card-color: CardColor.teal;
                width: 416px;
                height: 144px;

                HorizontalLayout {
                    padding: Size.sz4;
                    alignment: end;
                    VerticalLayout {
                        alignment: center;
                        CardPill {
                            line-color: CardColor.teal;

                            TextMd {
                                text: "Bitcoin";
                                color: UIColors.primary-white;
                                bold: true;
                            }
                        }
                    }
                }
            }
        }

        HorizontalLayout {
            spacing: Size.sz6;
            LineCard {
                card-color: CardColor.dark-copper;
                width: 416px;
                height: 144px;

                HorizontalLayout {
                    padding: Size.sz4;
                    alignment: end;
                    VerticalLayout {
                        alignment: center;
                        CardCircle {
                            line-color: CardColor.dark-copper;

                            Icon {
                                name: "lightning";
                                size: 60px;
                                color: UIColors.primary-white;
                            }
                        }
                    }
                }
            }

            LineCard {
                card-color: CardColor.light-copper;
                width: 416px;
                height: 144px;

                HorizontalLayout {
                    padding: Size.sz4;
                    alignment: end;
                    VerticalLayout {
                        alignment: center;
                        CardPill {
                            line-color: CardColor.light-copper;

                            TextMd {
                                text: "Lightning";
                                color: UIColors.primary-white;
                                bold: true;
                            }
                        }
                    }
                }
            }
        }

        HorizontalLayout {
            spacing: Size.sz6;
            LineCard {
                card-color: CardColor.pine;
                width: 416px;
                height: 144px;

                HorizontalLayout {
                    padding: Size.sz4;
                    alignment: end;
                    VerticalLayout {
                        alignment: center;
                        CardCircle {
