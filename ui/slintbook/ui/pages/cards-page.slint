            }

            LineCard {
                card-color: CardColor.green;
                width: 416px;
                height: 144px;

                HorizontalLayout {
                    padding: Size.sz4;
                    alignment: end;
                    VerticalLayout {
                        alignment: center;
                        CardPill {
                            line-color: CardColor.green;

                            TextMd {
                                text: "Shield";
                                color: UIColors.primary-white;
                                bold: true;
                            }
                        }
                    }
                }
            }
        }

        HorizontalLayout {
            spacing: Size.sz6;
            LineCard {
                card-color: CardColor.purple;
                width: 416px;
                height: 144px;

                HorizontalLayout {
                    padding: Size.sz4;
                    alignment: end;
                    VerticalLayout {
                        alignment: center;
                        CardCircle {
                            line-color: CardColor.purple;

