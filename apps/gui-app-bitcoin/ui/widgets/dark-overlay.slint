import { AppHeader, IconButton } from "@ui/widgets.slint";
import { Importance, Size } from "@ui/theme.slint";
import { DarkPalette } from "@ui/palettes/dark-palette.slint";

export component DarkOverlay inherits Rectangle {
    in property <bool> open: false;
    in property <string> title;
    in property <length> spacing: Size.sz8;

    callback closed;

    opacity: open ? 1 : 0;
    background: open ? DarkPalette.background-primary.transparentize(0.1) : transparent;

    animate background, opacity {
        duration: 300ms;
        easing: ease-in-out;
    }

    // disable touches through the overlay
    TouchArea {
        enabled: open;
    }

    Rectangle {
        // needed to prevent any touches from registering
        visible: open;

        VerticalLayout {
            alignment: start;
            spacing: spacing;

            AppHeader {
                title: title;
                title-color: DarkPalette.content-primary;
                alignment: end;

                IconButton {
                    icon: "close";
                    background: transparent;
                    icon-color: DarkPalette.content-primary;
                    clicked => {
                        closed();
                    }
                }
            }

            @children
        }
    }
}
