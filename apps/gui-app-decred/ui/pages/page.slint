//
// Home: a balance card (MOCK data until QuantumLink companion integration),
// the wordmark, and the core actions.

import { BasePage, AppHeader, PageBody, ContentSection, ButtonSection, Button, HeadingSm, TextSm } from "@ui/widgets.slint";
import { CardColor } from "@ui/theme.slint";
import { Balance } from "../balance.slint";
import { DcrAccountCard } from "../dcr-account-card.slint";
import { Palette, Size, Importance } from "@ui/theme.slint";
import { TR2, TrId } from "../gen/tr.slint";
import { Navigate } from "../gen/navigate.slint";

export component HomePage inherits BasePage {

    PageBody {
        ContentSection {
            spacing: Size.sz3;

            // MOCK balance card — placeholder values (see balance.slint).
            DcrAccountCard {
                name: "Decred";
                crypto-balance: Balance.dcr-amount;
                fiat-balance: Balance.fiat-amount;
            }

            // Prominent, centered mission line.
            Rectangle { height: 10px; }
            Text {
                text: "Air-gapped Signer";
                color: #ffffff;
                font-size: 28px;
                font-weight: 800;
                letter-spacing: 0.5px;
                horizontal-alignment: center;
            }
            Text {
                text: "COLD · OFFLINE · SECURE";
                color: #2970ff;
                font-size: 12px;
                font-weight: 700;
                letter-spacing: 3px;
                horizontal-alignment: center;
            }
        }

        ButtonSection {
            Button {
                label: TR2.lookup(TrId.HomeReceive);
                importance: Importance.primary;
                // App-scoped Decred blue (does not touch shared @ui theme).
                background: #2970ff;
                clicked => {
                    Navigate.receive({ });
                }
            }

            Button {
                label: TR2.lookup(TrId.HomeSign);
                importance: Importance.secondary;
                // Faint green outline to signal the signing action.
                border-width: 1px;
                border-color: #2dd8a3;
                clicked => {
                    Navigate.sign({ });
                }
            }

            Button {
                label: TR2.lookup(TrId.HomeExport);
                importance: Importance.secondary;
                clicked => {
                    Navigate.export({ });
                }
            }
            Button {
                label: TR2.lookup(TrId.HomeSeed);
                importance: Importance.secondary;
                clicked => {
                    Navigate.seed({ });
                }
            }
        }
    }
}
