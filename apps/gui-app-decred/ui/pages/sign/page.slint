// SPDX-License-Identifier: GPL-3.0-or-later
//
// Sign: the core flow. One page, driven by SignTx.state.
//   Idle     -> choose QR or SD as the source of the unsigned package
//   Scanning -> animated-QR capture in progress
//   Review   -> recipients / amount / fee, then Approve (fires the seed gate)
//   ShowQr   -> signed tx as animated QR to scan back into the companion
//   Done     -> signed tx written to SD card
//   Error    -> refused or failed

import { BasePage, NavHeader, PageBody, ContentSection, ButtonSection, Button, DynamicQrCode, HeadingSm, HeadingMd, TextMd, TextSm, HLine, TimerCircularProgress } from "@ui/widgets.slint";
import { Palette, Size, Importance } from "@ui/theme.slint";
import { TR2, TrId } from "../../gen/tr.slint";
import { Navigate } from "../../gen/navigate.slint";
import { SignTx, SignState } from "../../sign-tx.slint";

// A label/value row — used for the amount/fee summary.
component SummaryRow inherits HorizontalLayout {
    in property <string> label;
    in property <string> value;
    in property <bool> emphasis: false;

    TextMd {
        text: label;
        color: Palette.content-tertiary;
        horizontal-alignment: left;
    }

    Rectangle { }  // spacer

    TextMd {
        text: value;
        color: emphasis ? Palette.content-primary : Palette.content-secondary;
        horizontal-alignment: right;
    }
}

export component SignPage inherits BasePage {
    init => {
        // Always start the signing flow clean (don't reopen on a stale QR/Done).
        SignTx.reject();
    }
    NavHeader {
        clicked => {
            Navigate.backward();
        }
    }

    PageBody {
        ContentSection {
            spacing: Size.sz4;

            // --- Idle: pick a transport -------------------------------------
            if SignTx.state == SignState.Idle: VerticalLayout {
                spacing: Size.sz4;
                HeadingSm {
                    text: TR2.lookup(TrId.SignChooseSource);
                    horizontal-alignment: center;
                }

                TextSm {
                    text: TR2.lookup(TrId.SignChooseSourceHint);
                    color: Palette.content-tertiary;
                    horizontal-alignment: center;
                }
            }

            // --- Scanning ----------------------------------------------------
            if SignTx.state == SignState.Scanning: VerticalLayout {
                spacing: Size.sz4;
                HorizontalLayout {
                    alignment: center;
                    TimerCircularProgress {
                        indeterminate: true;
                    }
                }

                TextMd {
                    text: TR2.lookup(TrId.SignScanning);
                    horizontal-alignment: center;
                }
            }

            // --- Review (ported from decred_review.slint mockup) -------------
            if SignTx.state == SignState.Review: VerticalLayout {
                spacing: 0px;

                Text {
                    text: "Review transaction";
                    color: #ffffff;
                    font-size: 24px;
                    font-weight: 700;
                    horizontal-alignment: center;
                }
                Text {
                    text: "Verify every detail on this screen.";
                    color: #6b6b6b;
                    font-size: 13px;
                    horizontal-alignment: center;
                }

                Rectangle { height: 20px; }
                // HARD WARNING: companion mislabelled non-owned outputs as change.
                if SignTx.flagged-count > 0: Rectangle {
                    height: 92px;
                    border-radius: 16px;
                    background: #2a0e0e;
                    border-width: 1.5px;
                    border-color: #ff4d4d;
                    VerticalLayout {
                        padding: 12px;
                        spacing: 4px;
                        Text {
                            text: "⚠ SECURITY WARNING";
                            color: #ff6b6b;
                            font-size: 14px;
                            font-weight: 800;
                            letter-spacing: 1px;
                            horizontal-alignment: center;
                        }
                        Text {
                            text: "Your companion labelled an output as change that is NOT one of your addresses. A correct wallet never does this — it may be faulty or hostile. Verify the recipients below.";
                            color: #ffb3b3;
                            font-size: 12px;
                            horizontal-alignment: center;
                            wrap: word-wrap;
                        }
                    }
                }
                if SignTx.flagged-count > 0: Rectangle { height: 12px; }

                // Amount hero
                Rectangle {
                    height: 130px;
                    background: #08080a;
                    border-radius: 20px;
                    border-width: 1px;
                    border-color: #1c1c1c;
                    VerticalLayout {
                        alignment: center;
                        spacing: 4px;
                        Text {
                            text: "SENDING";
                            color: #2970ff;
                            font-size: 12px;
                            font-weight: 600;
                            letter-spacing: 2px;
                            horizontal-alignment: center;
                        }
                        Text {
                            text: SignTx.send-total;
                            color: #ffffff;
                            font-size: 38px;
                            font-weight: 700;
                            horizontal-alignment: center;
                        }
                    }
                }

                Rectangle { height: 14px; }

                // Detail card
                Rectangle {
                    background: #08080a;
                    border-radius: 20px;
                    border-width: 1px;
                    border-color: #1c1c1c;
                    VerticalLayout {
                        padding: 8px;
                        padding-left: 18px;
                        padding-right: 18px;
                        spacing: 0px;

                        // RECIPIENT — device-decoded destination; verify every character.
                        VerticalLayout {
                            padding-top: 10px;
                            padding-bottom: 10px;
                            spacing: 4px;
                            Text {
                                text: "SENDING TO";
                                color: #2970ff;
                                font-size: 12px;
                                font-weight: 600;
                                letter-spacing: 1.5px;
                            }
                            Text {
                                text: SignTx.recipient;
                                color: #ffffff;
                                font-size: 20px;
                                font-weight: 500;
                                wrap: char-wrap;
                            }
                        }
                        Rectangle { height: 1px; background: #161616; }
                        HorizontalLayout {
                            height: 44px;
                            Text {
                                text: "Network fee";
                                color: #6b6b6b;
                                font-size: 14px;
                                vertical-alignment: center;
                                horizontal-stretch: 1;
                            }
                            Text {
                                text: SignTx.fee;
                                color: #e8e8e8;
                                font-size: 15px;
                                font-weight: 500;
                                vertical-alignment: center;
                                horizontal-alignment: right;
                            }
                        }
                        Rectangle { height: 1px; background: #161616; }
                        HorizontalLayout {
                            height: 44px;
                            Text {
                                text: "Change";
                                color: #6b6b6b;
                                font-size: 14px;
                                vertical-alignment: center;
                                horizontal-stretch: 1;
                            }
                            Text {
                                text: SignTx.change;
                                color: #e8e8e8;
                                font-size: 15px;
                                font-weight: 500;
                                vertical-alignment: center;
                                horizontal-alignment: right;
                            }
                        }
                    }
                }
            }

            // --- ShowQr: signed, animated QR back ----------------------------
            if SignTx.state == SignState.ShowQr: VerticalLayout {
                spacing: Size.sz4;
                HeadingSm {
                    text: TR2.lookup(TrId.SignSignedTitle);
                    horizontal-alignment: center;
                }

                HorizontalLayout {
                    alignment: center;
                    DynamicQrCode {
                        get-parts(density) => {
                            SignTx.signed-qr-parts();
                        }
                    }
                }

                TextSm {
                    text: TR2.lookup(TrId.SignSignedQrHint);
                    color: Palette.content-tertiary;
                    horizontal-alignment: center;
                    wrap: word-wrap;
                }
            }

            // --- Done: written to SD ----------------------------------------
            if SignTx.state == SignState.Done: VerticalLayout {
                spacing: Size.sz3;
                HeadingSm {
                    text: TR2.lookup(TrId.SignSavedTitle);
                    horizontal-alignment: center;
                }

                TextSm {
                    text: SignTx.saved-path;
                    color: Palette.content-secondary;
                    horizontal-alignment: center;
                    wrap: word-wrap;
                }
            }

            // --- Error -------------------------------------------------------
            if SignTx.state == SignState.Error: TextMd {
                text: SignTx.error-text;
                color: Palette.content-tertiary;
                horizontal-alignment: center;
                wrap: word-wrap;
            }
        }

        ButtonSection {
            // Idle: the two entry points.
            if SignTx.state == SignState.Idle: Button {
                label: TR2.lookup(TrId.SignScanQr);
                importance: Importance.primary;
                background: #2970ff;
                clicked => {
                    SignTx.start-qr-scan();
                }
            }
            if SignTx.state == SignState.Idle: Button {
                label: TR2.lookup(TrId.SignLoadSd);
                importance: Importance.secondary;
                clicked => {
                    SignTx.load-from-sd();
                }
            }

            // Acknowledgment gate: when the companion lied about change, the
            // user MUST consciously acknowledge before Approve unlocks.
            if SignTx.state == SignState.Review && SignTx.flagged-count > 0 && !SignTx.mismatch-acknowledged: Button {
                label: "I understand — these are NOT change";
                importance: Importance.secondary;
                background: #5a1a1a;
                label-color: #ffd0d0;
                clicked => {
                    SignTx.mismatch-acknowledged = true;
                }
            }
            // Review: the consequential choice. Disabled while an unacknowledged
            // companion-mismatch is present, so it can't be signed reflexively.
            if SignTx.state == SignState.Review: Button {
                label: TR2.lookup(TrId.SignApprove);
                importance: Importance.primary;
                background: (SignTx.flagged-count > 0 && !SignTx.mismatch-acknowledged) ? #1a2a44 : #2970ff;
                label-color: #ffffff;
                enabled: !(SignTx.flagged-count > 0 && !SignTx.mismatch-acknowledged);
                clicked => {
                    SignTx.approve();
                }
            }
            if SignTx.state == SignState.Review: Button {
                label: TR2.lookup(TrId.SignReject);
                importance: Importance.secondary;
                clicked => {
                    SignTx.reject();
                }
            }

            // Terminal states: one way out.
            if SignTx.state == SignState.ShowQr || SignTx.state == SignState.Done || SignTx.state == SignState.Error: Button {
                label: TR2.lookup(TrId.CommonDone);
                importance: Importance.primary;
                clicked => {
                    SignTx.reject();
                    Navigate.backward();
                }
            }

            // Scanning: let the user back out.
            if SignTx.state == SignState.Scanning: Button {
                label: TR2.lookup(TrId.CommonCancel);
                importance: Importance.secondary;
                clicked => {
                    SignTx.reject();
                }
            }
        }
    }
}
