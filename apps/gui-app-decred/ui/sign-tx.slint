//
// Signing flow state shared between Rust (sign_tx.rs) and the Slint pages.
// The page renders one of these states; Rust drives transitions.

export enum SignState {
    // Nothing loaded — offer QR / SD entry points.
    Idle,
    // Camera open, assembling an animated-QR (UR) sign request.
    Scanning,
    // Decoded; showing recipients / amount / fee for confirmation.
    Review,
    // Signed; presenting the signed tx as an animated QR to scan back.
    ShowQr,
    // Signed; written to SD card.
    Done,
    // Something refused or failed (see error-text).
    Error,
}

export enum OriginView {
    Qr,
    SdCard,
}

// One external recipient, pre-formatted in Rust for on-device verification.
export struct RecipientRow {
    address: string,
    amount: string,
}

export global SignTx {
    in property <SignState> state: SignState.Idle;
    in property <OriginView> origin: OriginView.Qr;

    // Review summary, pre-formatted as "1.2345 DCR" strings in Rust because
    // Slint int is 32-bit and atom values overflow it.
    in property <string> send-total;
    in property <string> fee;
    in property <string> change;
    in property <int> recipient-count;
    // Per-recipient address + amount — THE critical thing to verify on-device.
    // Each row is shown individually so every destination amount is auditable.
    in property <[RecipientRow]> recipients;
    // Count of outputs the companion mislabelled as change but that
    // are NOT ours — a detected lie. >0 means show a hard warning and
    // gate the approve button.
    in property <int> flagged-count: 0;
    // Whether the user has acknowledged the mismatch warning.
    in-out property <bool> mismatch-acknowledged: false;

    // Result / failure surfaces.
    in property <string> saved-path;
    in property <string> error-text;

    // Animated-QR frames for the signed transaction (UR parts).
    pure callback signed-qr-parts() -> [string];

    // User actions.
    callback start-qr-scan();
    callback load-from-sd();
    callback approve();
    callback reject();
}
