                    input14 := SeedWordInput {
                        index: 13;
                        focus-next => {
                            input15.focus();
                        }
                    }

                    input15 := SeedWordInput {
                        index: 14;
                        focus-next => {
                            input16.focus();
                        }
                    }

                    input16 := SeedWordInput {
                        index: 15;
                        focus-next => {
                            input17.focus();
                        }
                    }

                    input17 := SeedWordInput {
                        index: 16;
                        focus-next => {
                            input18.focus();
                        }
                    }

                    input18 := SeedWordInput {
                        index: 17;
                        focus-next => {
                            input19.focus();
                        }
                    }

                    input19 := SeedWordInput {
                        index: 18;
                        focus-next => {
                            input20.focus();
                        }
                    }

                    input20 := SeedWordInput {
                        index: 19;
                        focus-next => {
                            input21.focus();
                        }
                    }

                    input21 := SeedWordInput {
                        index: 20;
                        focus-next => {
                            input22.focus();
                        }
                    }

                    input22 := SeedWordInput {
                        index: 21;
                        focus-next => {
                            input23.focus();
                        }
                    }

                    input23 := SeedWordInput {
                        index: 22;
                        focus-next => {
                            input24.focus();
                        }
                    }

                    input24 := SeedWordInput {
