}

component Success inherits JumboIconPageBody {
    RestoreSuccessContent { }

    ButtonSection {
        Button {
            label: TR2.lookup(TrId.CommonButtonContinue);
            importance: primary;
            clicked => {
                if (SeedGlobal.is-master-key-recovery) {
                    OnboardingCallbacks.finish-onboarding();
                } else {
                    Navigate.restore-magic-backup({ });
                }
            }
        }
    }
}

export component RestoreSeedWordsPage inherits OnboardingBasePage {
    property <MasterSeedState> state <=> SeedGlobal.master-seed-state;

    if state == MasterSeedState.Idle: Restoring { }
    if state == MasterSeedState.SavingToSE || state == MasterSeedState.EncryptingFs: RestoreSeedLoading { }
    if state == MasterSeedState.Success: Success { }
    if state == MasterSeedState.Failed: RestoreFailed {
        // TODO: formalize or remove
        title: "Failed to restore Master Seed";
        retry => {
            state = MasterSeedState.Idle;
        }
    }
}
