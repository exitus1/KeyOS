import { Button, ButtonSection, Icon, Shield, HeadingMd, TextSm, AppHeader, IconButton, ScrollBody, JumboIconPageBody } from "@ui/widgets.slint";
import { Images, Size, UISize} from "@ui/theme.slint";
import { OnboardingBasePage } from "../../../../widgets/base-page.slint";
import { Palette, Size, Utils, CardColor, UISize } from "@ui/theme.slint";
import { Navigate } from "../../../../gen/navigate.slint";
import { Input } from "@ui/widgets/input.slint";
import { TR2, TrId } from "../../../../gen/tr.slint";
import { OnboardingCallbacks,  MasterSeedState, SeedGlobal } from "../../../../onboarding-callbacks.slint";
import { RestoreSeedLoading, RestoreSuccessContent, RestoreFailed } from "../../../../widgets/restore-seed.slint";

global SeedState {
    in-out property <[string]> words;
    in-out property <bool> is-seed-valid;

    out property <bool> is-24-words: words.length == 24;

    public function seed-to-24-word() {
        words = [
            words[0],
            words[1],
            words[2],
            words[3],
            words[4],
            words[5],
            words[6],
            words[7],
            words[8],
            words[9],
            words[10],
            words[11],
            "",
            "",
            "",
            "",
            "",
            "",
            "",
            "",
            "",
            "",
            "",
            ""
        ];
    }

    public function set-word(index: int, word: string) {
        words[index] = word;
        is-seed-valid = SeedGlobal.validate-full-seed(words)
    }
}

component SeedWordInput inherits VerticalLayout {
    in property <int> index;
    out property <bool> is-last: index == SeedState.words.length - 1;
    out property <bool> valid: input.text != "" && SeedGlobal.validate-seed-word(input.text);
    callback focus-next();

    alignment: start;
    visible: index < SeedState.words.length;

    forward-focus: input;

    input := Input {
        show-clear-btn: false;
        text: SeedState.words[index];
        prefix: "\{index + 1}.";
        placeholder: TR2.format(TrId.RecoverWordsFillerText, [index + 1]);
        has-error: self.text != "" && !valid;
        height: root.visible ? Size.sz14 : 0px;

        edited(new-text) => {
            SeedState.set-word(index, new-text);
        }
        accepted(text) => {
            if (valid) {
                focus-next();
            }
        }
    }

    Rectangle {
        height: root.visible && !root.is-last ? Size.sz4 : 0px;
    }
}

component Restoring inherits Rectangle {
    init => {
        SeedState.words = ["", "", "", "", "", "", "", "", "", "", "", ""];
        SeedState.is-seed-valid = false;
    }

    VerticalLayout {
        alignment: stretch;
        AppHeader {
            title: TR2.lookup(TrId.RecoverWordsTilte);

            IconButton {
                icon: "chevron-left";
                clicked => {
                    Navigate.backward();
