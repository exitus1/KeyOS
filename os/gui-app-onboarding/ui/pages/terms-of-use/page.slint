                            wrap: TextWrap.word-wrap;
                            color: Palette.content-primary;
                        }

                        TextSm {
                            text: "Foundation Devices warrants Passport Prime hardware to be free from defects in materials and workmanship under normal use for one (1) year from the date of purchase.";
                            wrap: TextWrap.word-wrap;
                            color: Palette.content-primary;
