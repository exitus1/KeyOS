                        HeadingSm {
                            text: "11. LIMITATION OF LIABILITY";
                            wrap: TextWrap.word-wrap;
                            color: Palette.content-primary;
                        }

                        TextSm {
                            text: "TO THE MAXIMUM EXTENT PERMITTED BY LAW, FOUNDATION DEVICES AND ITS AFFILIATES, OFFICERS, EMPLOYEES, AND SUPPLIERS WILL NOT BE LIABLE FOR ANY INDIRECT, INCIDENTAL, CONSEQUENTIAL, SPECIAL, OR PUNITIVE DAMAGES (INCLUDING LOSS OF FUNDS, DATA, OR PROFITS) ARISING OUT OF YOUR USE OF PASSPORT PRIME OR THE SERVICES, EVEN IF WE HAVE BEEN ADVISED OF THE POSSIBILITY OF SUCH DAMAGES.";
                            wrap: TextWrap.word-wrap;
                            color: Palette.content-primary;
                        }

                        TextSm {
                            text: "IN NO EVENT SHALL OUR TOTAL LIABILITY EXCEED THE GREATER OF (A) ONE HUNDRED U.S. DOLLARS ($100) OR (B) THE AMOUNT YOU PAID FOR YOUR PASSPORT PRIME DEVICE.";
                            wrap: TextWrap.word-wrap;
                            color: Palette.content-primary;
                        }

                        TextSm {
                            text: "Some jurisdictions do not allow the limitation or exclusion of liability; these limitations may not apply to you.";
                            wrap: TextWrap.word-wrap;
                            color: Palette.content-primary;
                        }

                        Divider {
                            width: 50px;
                        }

                        HeadingSm {
                            text: "12. INDEMNIFICATION";
                            wrap: TextWrap.word-wrap;
                            color: Palette.content-primary;
                        }

                        TextSm {
                            text: "You agree to indemnify and hold harmless Foundation Devices and its officers, employees, and agents from any claims, damages, or expenses (including attorneys’ fees) arising from (a) your use of Passport Prime, (b) your breach of these Terms, or (c) your violation of law. We may assume defense of any claim at your expense.";
                            wrap: TextWrap.word-wrap;
                            color: Palette.content-primary;
                        }

                        Divider {
                            width: 50px;
                        }

                        HeadingSm {
                            text: "13. RELEASE";
                            wrap: TextWrap.word-wrap;
                            color: Palette.content-primary;
                        }

                        TextSm {
                            text: "You release and forever discharge Foundation Devices and its agents from all claims or liabilities arising from your use of Passport Prime or loss of digital assets. If you are a California resident, you waive California Civil Code § 1542.";
                            wrap: TextWrap.word-wrap;
                            color: Palette.content-primary;
                        }

                        Divider {
                            width: 50px;
                        }

                        HeadingSm {
                            text: "14. PRIVACY AND DATA";
                            wrap: TextWrap.word-wrap;
                            color: Palette.content-primary;
                        }

                        TextSm {
                            text: "Your use of Passport Prime and Envoy is subject to our Privacy Policy. Foundation Devices does not collect or store private keys or seed phrases from Passport Prime. Envoy may collect limited diagnostic data with your consent.";
                            wrap: TextWrap.word-wrap;
                            color: Palette.content-primary;
                        }

                        Divider {
                            width: 50px;
                        }

                        HeadingSm {
                            text: "15. DISPUTE RESOLUTION";
                            wrap: TextWrap.word-wrap;
                            color: Palette.content-primary;
                        }

                        TextSm {
                            text: "This Agreement is governed by the laws of the Commonwealth of Massachusetts, consistent with the Federal Arbitration Act. All disputes shall be resolved by binding arbitration under the JAMS rules referenced in Foundation Devices’ Website Terms of Use. You may opt out within 30 days by emailing hello@foundation.xyz.";
                            wrap: TextWrap.word-wrap;
                            color: Palette.content-primary;
                        }

                        Divider {
                            width: 50px;
                        }

                        HeadingSm {
                            text: "16. SURVIVAL AND GENERAL PROVISIONS";
                            wrap: TextWrap.word-wrap;
                            color: Palette.content-primary;
                        }

                        TextSm {
