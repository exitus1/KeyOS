                        TextSm {
                            text: "Passport Prime requires certain third-party equipment, software, and services (such as mobile devices, operating systems, Bluetooth stacks, and internet connectivity) and may interoperate with optional third-party products or services.";
                            wrap: TextWrap.word-wrap;
