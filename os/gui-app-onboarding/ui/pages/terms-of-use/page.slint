import { TextSm, BasePage, Divider, HeadingSm, NavHeader } from "@ui/widgets.slint";
import { Palette } from "@ui/theme.slint";
import { OnboardingBasePage } from "../../widgets/base-page.slint";
import { Size } from "@ui/theme.slint";
import { Navigate } from "../../gen/navigate.slint";
import { TermsOfUseProps } from "./props.slint";
import { IconButton } from "@ui/widgets/icon-button.slint";
import { TR2, TrId } from "../../gen/tr.slint";

export component TermsOfUsePage inherits OnboardingBasePage {
    in property <TermsOfUseProps> props;

    VerticalLayout {
        alignment: stretch;

        NavHeader {
            title: TR2.lookup(TrId.TermsOfUseTitle);
            clicked => {
                Navigate.backward();
            }
        }

        VerticalLayout {
            Flickable {
                width: parent.width;
                viewport-width: self.width;

                VerticalLayout {
                    padding-top: Size.sz4;
                    padding-bottom: Size.sz4;
                    padding-left: Size.sz7;
                    padding-right: Size.sz7;
                    spacing: Size.sz6;

                    TextSm {
                        text: "Last updated: November 11, 2025";
                        wrap: TextWrap.word-wrap;
                        color: Palette.content-tertiary;
                    }

                    TextSm {
                        text: "By purchasing, activating, or using a Passport Prime hardware device (“Passport Prime,” “device,” or “Product”), you (“you,” “user,” or “purchaser”) agree to be bound by these Terms of Use (the “Agreement”).\nIf you do not agree, do not set up or use Passport Prime. You must be at least 18 years old, or of legal age in your jurisdiction, to accept these Terms.\nYour use of Foundation Devices’ website (foundation.xyz) remains governed by the Website Terms of Use and Privacy Policy.";
                        wrap: TextWrap.word-wrap;
                        color: Palette.content-primary;
                    }

                    VerticalLayout {
                        spacing: Size.sz5;

                        HeadingSm {
                            text: "1. PRODUCT DESCRIPTION AND SCOPE";
                            wrap: TextWrap.word-wrap;
                            color: Palette.content-primary;
                        }

                        TextSm {
                            text: "(a) Passport Prime.";
                            bold: true;
                            wrap: TextWrap.word-wrap;
                            color: Palette.content-primary;
                        }

                        TextSm {
                            text: "Passport Prime is a secure, offline hardware device designed primarily for storing and managing Bitcoin private keys and facilitating Bitcoin transactions. Passport Prime does not connect to the Internet and communicates only via Bluetooth with the Envoy app or through physical means such as QR codes or microSD cards.";
                            wrap: TextWrap.word-wrap;
                            color: Palette.content-primary;
                        }

                        TextSm {
                            text: "(b) Envoy App.";
                            bold: true;
                            wrap: TextWrap.word-wrap;
                            color: Palette.content-primary;
                        }

                        TextSm {
                            text: "Envoy is a mobile companion app used for setup, firmware updates, and communication with the Bitcoin network. Envoy may, at the user’s option, store private keys for its own built-in hot wallet. Envoy does not store or have access to any private keys, seed phrases, or unencrypted data originating from Passport Prime.";
                            wrap: TextWrap.word-wrap;
                            color: Palette.content-primary;
                        }

                        TextSm {
                            text: "(c) NFC Keycard Backups.";
                            bold: true;
                            wrap: TextWrap.word-wrap;
                            color: Palette.content-primary;
                        }

                        TextSm {
                            text: "During setup, you may create a distributed backup of your Passport Prime’s seed and configuration data to NFC Keycards. These Keycards are the primary backup method. They are restorable only on a compatible Passport Prime. Foundation Devices cannot access, recover, or replace lost, damaged, or erased Keycards.";
                            wrap: TextWrap.word-wrap;
                            color: Palette.content-primary;
                        }

                        TextSm {
                            text: "(d) Magic Backups.";
                            bold: true;
                            wrap: TextWrap.word-wrap;
                            color: Palette.content-primary;
                        }

                        TextSm {
                            text: "Magic Backups is an optional encrypted backup service that allows you to back up encrypted Passport Prime data through Envoy. Encrypted backup data may be stored on Foundation Devices’ servers or trusted third-party infrastructure, but Foundation Devices never has access to the keys or credentials required to decrypt it.";
                            wrap: TextWrap.word-wrap;
                            color: Palette.content-primary;
                        }

                        TextSm {
                            text: "You are solely responsible for remembering and safeguarding the encryption password or recovery key needed to restore from Magic Backups. If you lose this key, your data and funds cannot be recovered.";
                            wrap: TextWrap.word-wrap;
                            color: Palette.content-primary;
                        }

                        TextSm {
                            text: "(e) Firmware and Updates.";
                            bold: true;
                            wrap: TextWrap.word-wrap;
                            color: Palette.content-primary;
                        }

                        TextSm {
                            text: "Passport Prime accepts only firmware that has been digitally signed by Foundation Devices, ensuring authenticity and integrity. Foundation Devices is not liable for any device malfunction, data loss, or security compromise arising from interrupted updates, hardware failure, or user error during installation.";
                            wrap: TextWrap.word-wrap;
                            color: Palette.content-primary;
                        }

                        TextSm {
                            text: "(f) Open Source Licenses.";
                            bold: true;
                            wrap: TextWrap.word-wrap;
                            color: Palette.content-primary;
                        }

                        TextSm {
                            text: "Passport Prime includes software licensed under the GNU General Public License v3 and other open-source licenses. Your use of such software is subject to those licenses, which prevail over this Agreement in the event of conflict.";
                            wrap: TextWrap.word-wrap;
                            color: Palette.content-primary;
                        }

                        Divider {
                            width: 50px;
                        }

                        HeadingSm {
                            text: "2. USE OF PASSPORT PRIME";
                            wrap: TextWrap.word-wrap;
                            color: Palette.content-primary;
                        }

                        TextSm {
                            text: "Passport Prime includes functionality to store and facilitate the transfer of Bitcoin (“Bitcoin”) and other compatible assets. Foundation Devices has no control over, and no responsibility for, any Bitcoin transactions, on-chain activity, or network confirmations. You agree to comply with all applicable laws, including anti-money-laundering (“AML”) and counter-terrorist-financing regulations, when using Passport Prime.";
                            wrap: TextWrap.word-wrap;
                            color: Palette.content-primary;
                        }

                        Divider {
                            width: 50px;
                        }

                        HeadingSm {
                            text: "3. USER RESPONSIBILITIES AND SECURITY";
                            wrap: TextWrap.word-wrap;
                            color: Palette.content-primary;
                        }

                        TextSm {
                            text: "(a) Self-Custody and Backups.";
                            bold: true;
                            wrap: TextWrap.word-wrap;
                            color: Palette.content-primary;
                        }

                        TextSm {
                            text: "You are solely responsible for securing your seed phrase, PIN, passphrase, NFC Keycards, Magic Backups encryption key, and any other credentials associated with your device. Foundation Devices does not have access to your private keys or unencrypted backups and cannot recover your credentials or funds.";
                            wrap: TextWrap.word-wrap;
                            color: Palette.content-primary;
                        }

                        TextSm {
                            text: "(b) Loss of Access.";
                            bold: true;
                            wrap: TextWrap.word-wrap;
                            color: Palette.content-primary;
                        }

                        TextSm {
                            text: "If you lose or destroy your Passport Prime, forget your PIN or passphrase, or lose access to your Keycards or Magic Backups credentials, your funds may be permanently lost. Foundation Devices bears no liability for such loss.";
                            wrap: TextWrap.word-wrap;
                            color: Palette.content-primary;
                        }

                        TextSm {
                            text: "(c) Permitted Research and Modifications.";
                            bold: true;
                            wrap: TextWrap.word-wrap;
                            color: Palette.content-primary;
                        }

                        TextSm {
                            text: "Because Passport Prime and its firmware are open source, you may inspect, analyze, or modify the code and hardware for educational, research, or security purposes, provided you act responsibly and in good faith. You may not distribute or use modified versions that mislead users, compromise security, or violate law.";
                            wrap: TextWrap.word-wrap;
                            color: Palette.content-primary;
                        }

                        TextSm {
                            text: "(d) Prohibited Use.";
                            bold: true;
                            wrap: TextWrap.word-wrap;
                            color: Palette.content-primary;
                        }

                        TextSm {
                            text: "You may not use the Products for illegal activities, including fraud or money laundering, or interfere with the security or integrity of Passport Prime. Do not remove or alter branding, trademarks, or legal notices.";
                            wrap: TextWrap.word-wrap;
                            color: Palette.content-primary;
                        }

                        TextSm {
                            text: "(e) No Financial Advice.";
                            bold: true;
                            wrap: TextWrap.word-wrap;
                            color: Palette.content-primary;
                        }

                        TextSm {
                            text: "Foundation Devices does not provide financial, investment, or tax advice. Information provided through Envoy or our documentation is for general information only.";
                            wrap: TextWrap.word-wrap;
                            color: Palette.content-primary;
                        }

                        Divider {
                            width: 50px;
                        }

                        HeadingSm {
                            text: "4. ASSUMPTION OF RISK";
                            wrap: TextWrap.word-wrap;
                            color: Palette.content-primary;
                        }

                        TextSm {
                            text: "You acknowledge and accept that:";
                            wrap: TextWrap.word-wrap;
                            color: Palette.content-primary;
                        }

                        TextSm {
                            text: "1. Bitcoin and related technologies are volatile and subject to loss.";
                            wrap: TextWrap.word-wrap;
                            color: Palette.content-primary;
                        }

                        TextSm {
