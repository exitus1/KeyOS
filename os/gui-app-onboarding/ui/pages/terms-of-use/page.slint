                            wrap: TextWrap.word-wrap;
                            color: Palette.content-primary;
                        }

                        Divider {
                            width: 50px;
                        }

                        HeadingSm {
                            text: "10. DISCLAIMER OF WARRANTIES";
                            wrap: TextWrap.word-wrap;
                            color: Palette.content-primary;
                        }

                        TextSm {
                            text: "THE PRODUCTS AND SERVICES ARE PROVIDED “AS IS” AND “AS AVAILABLE.” FOUNDATION DEVICES DISCLAIMS ALL WARRANTIES, EXPRESS OR IMPLIED, INCLUDING MERCHANTABILITY, FITNESS FOR A PARTICULAR PURPOSE, TITLE, AND NON-INFRINGEMENT.";
                            wrap: TextWrap.word-wrap;
                            color: Palette.content-primary;
                        }

                        TextSm {
