                            wrap: TextWrap.word-wrap;
                            color: Palette.content-primary;
                        }

                        TextSm {
                            text: "You may not assign this Agreement without our consent. If any provision is invalid, the remainder will remain in effect. Headings are for convenience only. This Agreement constitutes the entire understanding between you and Foundation Devices concerning Passport Prime.";
                            wrap: TextWrap.word-wrap;
                            color: Palette.content-primary;
