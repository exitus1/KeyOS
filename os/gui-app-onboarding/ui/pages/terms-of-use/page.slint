                        Divider {
                            width: 50px;
                        }

                        HeadingSm {
                            text: "17. CONTACT INFORMATION";
                            wrap: TextWrap.word-wrap;
                            color: Palette.content-primary;
                        }

                        TextSm {
                            text: "Foundation Devices, Inc.";
                            bold: true;
                            wrap: TextWrap.word-wrap;
                            color: Palette.content-primary;
                        }

                        TextSm {
                            text: "6 Liberty Square #6018";
                            wrap: TextWrap.word-wrap;
                            color: Palette.content-primary;
                        }

                        TextSm {
                            text: "Boston, MA 02109";
                            wrap: TextWrap.word-wrap;
                            color: Palette.content-primary;
                        }

                        TextSm {
