                            wrap: TextWrap.word-wrap;
                            color: Palette.content-primary;
                        }

                        Divider {
                            width: 50px;
                        }

                        HeadingSm {
                            text: "6. TRANSFER OF PASSPORT PRIME";
                            wrap: TextWrap.word-wrap;
                            color: Palette.content-primary;
                        }

                        TextSm {
