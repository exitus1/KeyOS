                            wrap: TextWrap.word-wrap;
                            color: Palette.content-primary;
                        }

                        Divider {
                            width: 50px;
                        }

                        HeadingSm {
                            text: "7. OWNERSHIP AND FEEDBACK";
                            wrap: TextWrap.word-wrap;
                            color: Palette.content-primary;
                        }

                        TextSm {
