import { Button, TextLg, Icon, JumboIcon, Shield, HeadingMd, TextMd, TimerCircularProgress, HeadingSm, HeadingLg, Input, ButtonSection, NavHeader } from "@ui/widgets.slint";
import { OnboardingBasePage } from "../../../../widgets/base-page.slint";
import { Font } from "@ui/fonts.slint";
import { Palette, Size, Utils, UISize, Importance } from "@ui/theme.slint";
import { VerifySeedWordsProps } from "props.slint";
import { Navigate } from "../../../../gen/navigate.slint";
import { SeedGlobal, SeedWordChallenge } from "../../../../onboarding-callbacks.slint";
import { TR2, TrId } from "../../../../gen/tr.slint";
import { Pagination } from "../../../../widgets/pagination.slint";

enum WordState {
    Pending,
    Success,
    Failure
}

export component VerifySeedWordsPage inherits OnboardingBasePage {
    in property <VerifySeedWordsProps> props;

    // Get verification challenges from callback
    property <[SeedWordChallenge]> challenges: SeedGlobal.generate-seed-word-challenges(4);

    property <WordState> word-state: WordState.Pending;

    property <int> current-page:0;
    property <bool> seed-verified: current-page >= challenges.length;
    property <SeedWordChallenge> current-challenge: challenges[current-page];

    function subheader() -> string {
        if (word-state == WordState.Pending) {
            return TR2.lookup(TrId.BackupManualVerifyChooseWord);
        } else if (word-state == WordState.Failure) {
            return TR2.lookup(TrId.BackupManualVerifyIncorrectRestart);
        } else {
            return TR2.lookup(TrId.BackupManualVerifyCorrect);
        }
    }

    function subheader-color() -> brush {
        if (word-state == WordState.Pending) {
            return Palette.content-tertiary;
        } else if (word-state == WordState.Failure) {
            return Palette.content-copper-brand;
        } else {
            return Palette.content-brand;
        }
    }

    function verify-selection(selected-index: int) -> bool {
        if (selected-index == current-challenge.correct-option-index) {
            if (current-page == challenges.length - 1) {
                Navigate.backup-created({ });
            }
            word-state = WordState.Success;
            return true;
        } else {
            word-state = WordState.Failure;
            return false;
        }
    }

    function button-label() -> string {
        if (word-state == WordState.Pending && current-page < 3) {
            return TR2.lookup(TrId.BackupManualVerifyTapOnWord);
        }
        if (current-page >= 3) {
            return TR2.lookup(TrId.CommonButtonFinish);
        }
        if (word-state == WordState.Failure) {
            return TR2.lookup(TrId.BackupManualVerifyRestartVerification);
        }
        return TR2.lookup(TrId.CommonButtonNext);
    }

    VerticalLayout {
        NavHeader {
            title: TR2.lookup(TrId.BackupManualVerifyTitle);

            clicked => {
                Navigate.backward();
            }
        }

        VerticalLayout {
            padding-bottom: Size.sz4;
            padding-left: Size.sz4;
            padding-right: Size.sz4;

            correct-seed := VerticalLayout {
                spacing: Size.sz16;
                padding-top: Size.sz12;

                alignment: start;

                VerticalLayout {
                    alignment: start;
                    spacing: Size.sz3;
                    HeadingSm {
                        text: TR2.lookup(TrId.BackupManualVerifyTapOnWord);
                        color: Palette.content-secondary;
                        horizontal-alignment: center;
                    }

                    HeadingLg {
                        text: "#\{current-challenge.word-index + 1}";
                        color: Palette.content-secondary;
                        horizontal-alignment: center;
                    }
                }

                VerticalLayout {
                    alignment: start;
                    spacing: Size.sz6;
                    TextMd {
                        text: subheader();
                        color: subheader-color();
                        horizontal-alignment: center;
                    }

                    HorizontalLayout {
                        spacing: Size.sz6;
                        option-a := Button {
                            importance: secondary;
                            label: current-challenge.options[0];
                            width: 212px;
                            clicked => {
                                if (word-state != WordState.Pending) {
                                    return;
                                }
                                if (verify-selection(0)) {
                                    self.importance = Importance.primary;
                                } else {
                                    self.importance = Importance.notice;
                                }
                            }
                        }

                        option-b := Button {
                            importance: secondary;
                            label: current-challenge.options[1];
                            width: 212px;
                            clicked => {
                                if (word-state != WordState.Pending) {
                                    return;
                                }
                                if (verify-selection(1)) {
                                    self.importance = Importance.primary;
                                } else {
                                    self.importance = Importance.notice;
                                }
                            }
                        }
                    }

                    HorizontalLayout {
                        spacing: Size.sz6;
                        option-c := Button {
                            importance: secondary;
                            label: current-challenge.options[2];
                            width: 212px;
                            clicked => {
                                if (word-state != WordState.Pending) {
                                    return;
                                }
                                if (verify-selection(2)) {
                                    self.importance = Importance.primary;
                                } else {
                                    self.importance = Importance.notice;
                                }
                            }
                        }

                        option-d := Button {
                            importance: secondary;
                            label: current-challenge.options[3];
                            width: 212px;
                            clicked => {
                                if (word-state != WordState.Pending) {
                                    return;
                                }
                                if (verify-selection(3)) {
                                    self.importance = Importance.primary;
                                } else {
                                    self.importance = Importance.notice;
                                }
                            }
                        }
                    }
                }
            }

            ButtonSection {
                HorizontalLayout {
                    alignment: center;
                    Pagination {
                        current-page: current-page;
                        total-pages: 4;
                    }
                }

                Button {
                    label: button-label();
                    importance: primary;
                    enabled: word-state != WordState.Pending;
                    clicked => {
                        if (word-state == WordState.Failure) {
                            current-page = 0;
                        } else {
                            current-page += 1;
                        }
                        word-state = WordState.Pending;
                        option-a.importance = Importance.secondary;
                        option-b.importance = Importance.secondary;
                        option-c.importance = Importance.secondary;
                        option-d.importance = Importance.secondary;
                    }
                }
            }
        }
    }
}
