import { Palette, UISize, Size, Images } from "@ui/theme.slint";
import { Navigate } from "../../../gen/navigate.slint";
import { HeadingMd, TextSm, TextMd, Icon, Shield, Button, ButtonSection } from "@ui/widgets.slint";
import { OnboardingBasePage } from "../../../widgets/base-page.slint";
import { StepLine, StepLineSection } from "@ui/widgets/step-list.slint";
import { OnboardingCallbacks, SecurityCheckState, FirmwareCheckState } from "../../../onboarding-callbacks.slint";
import { ShieldSection, ShieldContent, OnboardingShieldPage, OverlayImage } from "../../../widgets/shield-page.slint";
import { TR2, TrId } from "../../../gen/tr.slint";


component Header inherits HeadingMd {
    vertical-stretch: 0;
    text: TR2.lookup(TrId.ConnectionHeader);
    horizontal-alignment: center;
}

component Connected inherits StepLine {
    done: true;
    text: TR2.lookup(TrId.ConnectionConnectedToEnvoy);
}

component SecurityCheckingView inherits ShieldSection {
    ShieldContent {
        Header { }

        StepLineSection {
            Connected { }

            StepLine {
                loading: true;
                text: TR2.lookup(TrId.ConnectionCheckingDeviceSecurity);
            }

            StepLine {
                text: TR2.lookup(TrId.ConnectionCheckForUpdates);
            }
        }
    }
}

component SecurityCheckFailedView inherits ShieldSection {
    ShieldContent {
        HeadingMd {
            vertical-stretch: 0;
            text: TR2.lookup(TrId.ErrorHeader);
            horizontal-alignment: center;
        }

        StepLineSection {
            Connected { }

            StepLine {
                error: true;
                text: TR2.lookup(TrId.ErrorSecurityCheckFailedWarning);
            }
        }

        TextSm {
            text: TR2.lookup(TrId.ErrorSecurityCheckFailedContent);
            horizontal-alignment: center;
        }
    }

    ButtonSection {
        Button {
            label: TR2.lookup(TrId.CommonButtonRetry);
            importance: primary;
            clicked => {
                OnboardingCallbacks.restart-onboarding();
            }
        }
    }
}

component SecurityCheckPendingView inherits ShieldSection {
